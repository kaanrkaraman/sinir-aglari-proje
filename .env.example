# Copy to `.env` and fill in. All vars are optional unless flagged REQUIRED.
# See src/annrag/config.py for the authoritative schema.

# ---- paths (defaults: <repo>/data and <repo>/artifacts) ---------------------
# ANNRAG_DATA_DIR=./data
# ANNRAG_ARTIFACTS_DIR=./artifacts

# ---- runtime ---------------------------------------------------------------
# ANNRAG_LOG_LEVEL=INFO
# ANNRAG_RANDOM_SEED=42

# ---- LLM / embedding API keys (added in later milestones) -------------------
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# COHERE_API_KEY=
